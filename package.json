{
  "name": "harness-studio-obsidian",
  "version": "0.1.0",
  "description": "Obsidian plugin providing UX for SSOT annotation management",
  "main": "main.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint --fix src/ tests/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "security:semgrep": "semgrep --config=auto --config=.semgrep/ src/",
    "build": "node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "verify": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "keywords": ["obsidian", "plugin", "ssot", "annotations"],
  "author": "KangGyeongGu",
  "license": "MIT",
  "devDependencies": {
    "@stryker-mutator/api": "^9.0.1",
    "@stryker-mutator/core": "^9.0.1",
    "@stryker-mutator/vitest-runner": "^9.0.1",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.17.0",
    "@vitest/eslint-plugin": "^1.1.0",
    "jsdom": "^26.0.0",
    "msw": "^2.7.0",
    "obsidian": "latest",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^3.0.0"
  }
}
